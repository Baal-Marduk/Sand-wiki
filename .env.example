# Copy to `.env` on the VPS and fill in real values. `.env` is gitignored.
# docker-compose reads this file automatically.

# Public hostname Caddy will obtain a TLS cert for. Its DNS A record must point
# at the VPS public IP before the first `docker compose up`.
DOMAIN=wiki.example.com

# --- PostgreSQL (self-hosted in the `db` service) ---
POSTGRES_USER=sandwiki
POSTGRES_PASSWORD=replace-with-a-long-random-secret
POSTGRES_DB=sandwiki

# --- Prisma connection strings ---
# `db` is the compose service hostname on the internal network. There is no
# pgbouncer here, so DIRECT_DATABASE_URL (used by `prisma migrate`) and
# DATABASE_URL (used at runtime) point at the same single Postgres.
# Keep the credentials in sync with POSTGRES_* above.
DATABASE_URL=postgresql://sandwiki:replace-with-a-long-random-secret@db:5432/sandwiki
DIRECT_DATABASE_URL=postgresql://sandwiki:replace-with-a-long-random-secret@db:5432/sandwiki
