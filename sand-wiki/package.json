{
  "name": "sand-wiki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:force": "tsx prisma/seed.ts --force",
    "db:load-location-recipes": "tsx prisma/load-location-recipes.ts",
    "db:load-key-progression": "tsx prisma/load-key-progression.ts",
    "db:load-new-ammo": "tsx prisma/load-new-ammo.ts",
    "db:load-curated-extras": "tsx prisma/load-curated-extras.ts",
    "db:migrate-buy-options": "tsx prisma/migrate-coin-trades-to-buy.ts",
    "db:extract-tech-unlocks": "tsx prisma/extract-tech-unlocks-to-buy.ts",
    "db:reset": "prisma migrate reset --force",
    "directus:up": "docker compose up -d directus",
    "directus:down": "docker compose down",
    "directus:snapshot": "docker compose exec directus npx directus schema snapshot --yes ./snapshots/snapshot.yaml",
    "directus:apply": "docker compose exec directus npx directus schema apply --yes ./snapshots/snapshot.yaml",
    "directus:moderator": "node prisma/setup-directus-moderator.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.7",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
