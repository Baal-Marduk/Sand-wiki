DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# Same URL without Neon's "-pooler" host suffix — used only by prisma migrate
# (advisory locks don't survive pgbouncer; deploys hang on the pooler URL)
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@DIRECT-HOST:5432/DBNAME?sslmode=require"

# Directus backoffice (local Docker)
DIRECTUS_SECRET="64-hex-string (node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\")"
# NB: must pass Directus email validation (".local" TLD is rejected)
DIRECTUS_ADMIN_EMAIL="admin@sand-wiki.dev"
DIRECTUS_ADMIN_PASSWORD="strong-random-password"
