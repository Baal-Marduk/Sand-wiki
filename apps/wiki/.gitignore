# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
/test-results/
/playwright-report/

# superpowers brainstorm
/.superpowers/

# machine-local docker compose overrides
docker-compose.override.yml

# Directus runtime uploads (mirrored sprites; recreated by prisma/sync-directus-icons.mjs)
/directus/uploads

# gallery thumbnail uploads (dev default THUMBS_DIR; written at publish)
# anchored so it only ignores apps/wiki/uploads/, not src/app/api/uploads/ route source
/uploads/

# /map 3D viewer: baked location meshes (~500MB) live off-repo (Vercel Blob).
# The tiny manifest.json/spawns.json fixtures stay committed; the big meshes never do.
/public/map/*.glb.gz

# datamine loot chain: game files + intermediate extracts are large/local-only
/datamine/gamefiles/
/datamine/extracted/*
!/datamine/extracted/.gitkeep
__pycache__/
*.pyc
