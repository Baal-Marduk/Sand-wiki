DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# Same URL without Neon's "-pooler" host suffix — used only by prisma migrate
# (advisory locks don't survive pgbouncer; deploys hang on the pooler URL)
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@DIRECT-HOST:5432/DBNAME?sslmode=require"

# Directus backoffice (local Docker)
DIRECTUS_SECRET="64-hex-string (node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\")"
# NB: must pass Directus email validation (".local" TLD is rejected)
DIRECTUS_ADMIN_EMAIL="admin@sand-wiki.dev"
DIRECTUS_ADMIN_PASSWORD="strong-random-password"

# Steam community contributions
# Long random string; signs the session cookie (node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=""
# Optional; enables persona name + avatar on login (https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=""
# Comma-separated 64-bit steamids allowed to review/apply proposals at /admin/proposals
ADMIN_STEAM_IDS=""
# Public origin used for the OpenID realm/return_to, e.g. https://wiki.example.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# /map 3D viewer asset base. The ~500MB baked location meshes live off-repo (Vercel Blob).
# Leave UNSET to serve from the local public/map/ folder (dev, after a local bake).
# In production set to the Blob base URL printed by scripts/upload-map-assets.mjs, e.g.
# NEXT_PUBLIC_MAP_ASSETS_BASE="https://<store-id>.public.blob.vercel-storage.com/map/"
NEXT_PUBLIC_MAP_ASSETS_BASE=""
